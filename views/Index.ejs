<!DOCTYPE html>
<html>
<head>
  <title>Course Portal</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center">

  <div class="bg-white shadow-xl rounded-2xl p-10 w-full max-w-md text-center">
    
    <h1 class="text-3xl font-bold text-blue-700 mb-4">
      University Course Portal
    </h1>

    <p class="text-gray-600 mb-6">
      Welcome! Learn, teach, and manage courses easily.
    </p>

    <div class="space-y-4">
      
      <a href="/register"
         class="block w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
        Register
      </a>

      <a href="/login"
         class="block w-full bg-gray-800 text-white py-3 rounded-lg font-semibold hover:bg-gray-900 transition">
        Login
      </a>

    </div>

  </div>

</body>
</html>