<!DOCTYPE html>
<html>
<head>
  <title>Courses</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">

  <nav class="bg-blue-700 text-white p-4 flex justify-between">
    <h1 class="font-bold text-xl">Course Portal</h1>
    <div class="space-x-3">
      <a href="/dashboard" class="hover:underline">Dashboard</a>
      <a href="/logout" class="bg-red-500 px-4 py-2 rounded-lg hover:bg-red-600">Logout</a>
    </div>
  </nav>

  <main class="max-w-6xl mx-auto p-6">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-3xl font-bold text-gray-800">Courses</h2>

      <% if (currentUser.role === "admin" || currentUser.role === "teacher") { %>
        <a href="/courses/new" class="bg-green-600 text-white px-5 py-3 rounded-lg hover:bg-green-700">
          Create New Course
        </a>
      <% } %>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% courses.forEach(course => { %>
        <div class="bg-white rounded-2xl shadow-lg p-6">
          <h3 class="text-xl font-bold text-blue-700 mb-2"><%= course.title %></h3>

          <p class="text-gray-600 mb-3"><%= course.description %></p>

          <p class="text-sm text-gray-500 mb-2">
            <strong>Category:</strong> <%= course.category %>
          </p>

          <p class="text-sm text-gray-500 mb-4">
            <strong>Teacher:</strong>
            <%= course.teacher ? course.teacher.name : "No teacher" %>
          </p>

          <div class="space-y-2">
            <a href="<%= course.videoUrl %>" target="_blank"
               class="block text-center bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700">
              Watch Video
            </a>

            <a href="/courses/<%= course._id %>/assignments"
               class="block text-center bg-purple-600 text-white py-2 rounded-lg hover:bg-purple-700">
              Assignments
            </a>
          </div>

          <% if (currentUser.role === "admin" || currentUser.role === "teacher") { %>
            <div class="flex gap-2 mt-4">
              <a href="/courses/<%= course._id %>/edit"
                 class="flex-1 text-center bg-yellow-500 text-white py-2 rounded-lg hover:bg-yellow-600">
                Edit
              </a>

              <form method="POST" action="/courses/<%= course._id %>/delete" class="flex-1">
                <button class="w-full bg-red-500 text-white py-2 rounded-lg hover:bg-red-600">
                  Delete
                </button>
              </form>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  </main>

</body>
</html>