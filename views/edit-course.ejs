<!DOCTYPE html>
<html>
<head>
  <title>Edit Course</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">

  <nav class="bg-blue-700 text-white p-4 flex justify-between">
    <h1 class="font-bold text-xl">Course Portal</h1>
    <a href="/courses" class="hover:underline">Back</a>
  </nav>

  <div class="max-w-xl mx-auto mt-10 bg-white p-8 rounded-2xl shadow-lg">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Edit Course</h2>

    <form method="POST" action="/courses/<%= course._id %>" class="space-y-4">
      <input class="w-full border p-3 rounded-lg" type="text" name="title" value="<%= course.title %>" required>

      <textarea class="w-full border p-3 rounded-lg" name="description" required><%= course.description %></textarea>

      <input class="w-full border p-3 rounded-lg" type="text" name="category" value="<%= course.category %>" required>

      <input class="w-full border p-3 rounded-lg" type="text" name="videoUrl" value="<%= course.videoUrl %>" required>

      <button class="w-full bg-yellow-500 text-white py-3 rounded-lg hover:bg-yellow-600">
        Update Course
      </button>
    </form>
  </div>

</body>
</html>